---
import Layout from '../components/Layout.astro';

const palettes = [
  {
    id: 'warm-ivory',
    name: 'Warm Ivory',
    note: 'Friendly, premium, calm. Best all-around for service trust.',
    page: '#FEFEFA',
    surface: '#FFFFFF',
    soft: '#F7F4EE',
    text: '#1F2430',
    muted: '#616B7C',
    border: '#DDD7CC',
    accent: '#6E5331',
    accentSoft: '#9A7B4F',
  },
  {
    id: 'cool-stone',
    name: 'Cool Stone',
    note: 'Clean and modern, slightly more tech-forward.',
    page: '#F7F9FC',
    surface: '#FFFFFF',
    soft: '#EEF2F7',
    text: '#1F2937',
    muted: '#667085',
    border: '#D7DFEA',
    accent: '#334155',
    accentSoft: '#64748B',
  },
  {
    id: 'soft-sand',
    name: 'Soft Sand',
    note: 'Most approachable and warm, less corporate.',
    page: '#FAF6EF',
    surface: '#FFFDF9',
    soft: '#F4EEE3',
    text: '#2A2A2A',
    muted: '#6E6A63',
    border: '#DED3C2',
    accent: '#7D5B3A',
    accentSoft: '#B08B63',
  },
  {
    id: 'sage-paper',
    name: 'Sage Paper',
    note: 'Subtle personality, calm and editorial.',
    page: '#F6F8F4',
    surface: '#FFFFFF',
    soft: '#EDF1EA',
    text: '#223027',
    muted: '#5E6C61',
    border: '#D5DED5',
    accent: '#3F5A4A',
    accentSoft: '#6F8B79',
  },
  {
    id: 'champagne-stone',
    name: 'Champagne Stone',
    note: 'Premium and calm, with a polished consultancy feel.',
    page: '#FCF9F3',
    surface: '#FFFFFF',
    soft: '#F3EDE2',
    text: '#23262F',
    muted: '#6B7080',
    border: '#DDD3C4',
    accent: '#7A6545',
    accentSoft: '#B09672',
  },
  {
    id: 'linen-ink',
    name: 'Linen Ink',
    note: 'High readability and strong contrast without looking harsh.',
    page: '#F9F8F5',
    surface: '#FFFFFF',
    soft: '#F1EFEB',
    text: '#1B2330',
    muted: '#5F697A',
    border: '#D7D8D2',
    accent: '#2F465E',
    accentSoft: '#647E99',
  },
  {
    id: 'pearl-ash',
    name: 'Pearl Ash',
    note: 'Minimal and modern, good for broad non-technical audiences.',
    page: '#F8FAFB',
    surface: '#FFFFFF',
    soft: '#EFF3F6',
    text: '#202733',
    muted: '#667283',
    border: '#D7E0E8',
    accent: '#415A77',
    accentSoft: '#7A94B1',
  },
  {
    id: 'terracotta-cream',
    name: 'Terracotta Cream',
    note: 'Most human and warm, strong for personal-brand trust.',
    page: '#FBF5ED',
    surface: '#FFFCF8',
    soft: '#F6EBDD',
    text: '#2A2420',
    muted: '#75655A',
    border: '#E3D3C0',
    accent: '#8A4E3A',
    accentSoft: '#BE7B63',
  },
  {
    id: 'mist-blue',
    name: 'Mist Blue',
    note: 'Soft, clean, and professional with a modern product vibe.',
    page: '#F5F8FC',
    surface: '#FFFFFF',
    soft: '#EAF0F8',
    text: '#1F2A3A',
    muted: '#637489',
    border: '#D2DDEC',
    accent: '#365A84',
    accentSoft: '#6C8FB9',
  },
] as const;
---

<Layout
  title="Light palettes lab — Michael Low"
  description="Compare multiple light-theme palette directions for the site redesign."
>
  <section class="border-b border-border py-12 md:py-16">
    <div class="container-main">
      <p class="section-label">Preview board</p>
      <h1 class="mt-4 font-sans text-4xl font-medium tracking-tight text-off-white md:text-5xl">
        Light-theme palette options
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-muted">
        Same layout, different palettes. Pick a palette family first, then we apply it to the full
        site redesign.
      </p>
      <div class="mt-6 flex flex-wrap gap-4 text-xs">
        <a href="/light-mode-redesign-lab" class="link-arrow">← Light redesign lab</a>
        <a href="/" class="link-arrow">Live homepage</a>
      </div>
    </div>
  </section>

  {
    palettes.map((p) => (
      <section class="border-b border-border py-14 md:py-16">
        <div class="container-main">
          <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-amber-accent">{p.name}</p>
          <p class="mt-2 max-w-2xl text-sm text-muted">{p.note}</p>

          <div class="mt-6 grid gap-2 sm:grid-cols-4 lg:grid-cols-8">
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.page}; border-color:${p.border}; color:${p.text};`}>
              <p class="font-medium">Page</p>
              <p class="font-mono">{p.page}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.surface}; border-color:${p.border}; color:${p.text};`}>
              <p class="font-medium">Surface</p>
              <p class="font-mono">{p.surface}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.soft}; border-color:${p.border}; color:${p.text};`}>
              <p class="font-medium">Soft</p>
              <p class="font-mono">{p.soft}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.text}; border-color:${p.text}; color:#fff;`}>
              <p class="font-medium">Text</p>
              <p class="font-mono">{p.text}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.muted}; border-color:${p.muted}; color:#fff;`}>
              <p class="font-medium">Muted</p>
              <p class="font-mono">{p.muted}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.border}; border-color:${p.border}; color:${p.text};`}>
              <p class="font-medium">Border</p>
              <p class="font-mono">{p.border}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.accent}; border-color:${p.accent}; color:#fff;`}>
              <p class="font-medium">Accent</p>
              <p class="font-mono">{p.accent}</p>
            </div>
            <div class="rounded-md border p-2 text-[11px]" style={`background:${p.accentSoft}; border-color:${p.accentSoft}; color:#fff;`}>
              <p class="font-medium">Accent 2</p>
              <p class="font-mono">{p.accentSoft}</p>
            </div>
          </div>

          <div class="mt-7 overflow-hidden rounded-3xl border shadow-[0_8px_28px_rgba(0,0,0,0.08)]" style={`background:${p.page}; border-color:${p.border};`}>
            <div class="border-b px-6 py-4 text-sm" style={`border-color:${p.border}; color:${p.muted};`}>
              Home · Work · Contact preview
            </div>
            <div class="grid gap-8 px-6 py-8 lg:grid-cols-2 lg:items-center lg:px-10" style={`color:${p.text};`}>
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.14em]" style={`color:${p.muted};`}>Practical AI implementation</p>
                <h2 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Make AI useful, not overwhelming.</h2>
                <p class="mt-4 max-w-xl text-base leading-relaxed" style={`color:${p.muted};`}>
                  I help small teams organise scattered information, automate repeated tasks, and build practical systems.
                </p>
                <div class="mt-6 flex flex-wrap items-center gap-4">
                  <a class="inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-medium text-white" style={`background:${p.accent};`} href="/contact">
                    Book a call
                  </a>
                  <a class="inline-flex items-center gap-2 text-sm font-medium" style={`color:${p.text};`} href="/work">
                    See how I work <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
              <div class="rounded-2xl border p-5 font-mono text-sm" style={`background:${p.surface}; border-color:${p.border}; color:${p.text};`}>
                <p>inputs.organise()</p>
                <p class="mt-2">repeat_tasks.automate()</p>
                <p class="mt-2">system.build()</p>
                <p class="mt-2" style={`color:${p.accentSoft};`}>→ clean_system.ready()</p>
              </div>
            </div>
            <div class="border-t px-6 py-8 lg:px-10" style={`background:${p.surface}; border-color:${p.border};`}>
              <div class="grid gap-4 md:grid-cols-3">
                <div class="rounded-xl border p-4" style={`background:${p.page}; border-color:${p.border};`}>
                  <p class="font-medium" style={`color:${p.text};`}>Manual admin loops</p>
                  <p class="mt-2 text-sm" style={`color:${p.muted};`}>Automate repeated tasks.</p>
                </div>
                <div class="rounded-xl border p-4" style={`background:${p.page}; border-color:${p.border};`}>
                  <p class="font-medium" style={`color:${p.text};`}>Scattered information</p>
                  <p class="mt-2 text-sm" style={`color:${p.muted};`}>Unify notes and docs.</p>
                </div>
                <div class="rounded-xl border p-4" style={`background:${p.page}; border-color:${p.border};`}>
                  <p class="font-medium" style={`color:${p.text};`}>No clear workflow</p>
                  <p class="mt-2 text-sm" style={`color:${p.muted};`}>Build systems teams can run.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <section class="section-padding">
    <div class="container-main">
      <div class="rounded-2xl border border-amber-accent/20 bg-charcoal-card/40 p-6">
        <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-amber-accent">Pick a direction</p>
        <p class="mt-3 text-sm text-muted">
          Best brand-fit for your services: <strong class="text-off-white">Warm Ivory</strong>,
          <strong class="text-off-white">Champagne Stone</strong>, and
          <strong class="text-off-white">Terracotta Cream</strong>. For a more product/modern feel, use
          <strong class="text-off-white">Linen Ink</strong> or <strong class="text-off-white">Mist Blue</strong>.
        </p>
      </div>
    </div>
  </section>
</Layout>
