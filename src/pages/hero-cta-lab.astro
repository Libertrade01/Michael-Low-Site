---
import Layout from '../components/Layout.astro';
import HeroCtaLabFrame from '../components/lab/HeroCtaLabFrame.astro';
---

<Layout
  title="Hero CTA options — Michael Low"
  description="Compare primary and secondary call-to-action layouts for the homepage hero."
>
  <header class="border-b border-border py-12">
    <div class="container-main">
      <p class="section-label">Preview board</p>
      <h1 class="mt-4 font-serif text-4xl text-off-white md:text-5xl">Hero CTA options</h1>
      <p class="mt-4 max-w-2xl text-muted">
        Same headline, intro, and availability pill on each mockup. Compare layout first, then
        secondary link copy. Pick one pair for the live homepage.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/" class="font-mono text-xs uppercase tracking-wider text-amber-accent hover:underline">
          ← Homepage
        </a>
        <a
          href="/hero-status-lab"
          class="font-mono text-xs uppercase tracking-wider text-muted hover:text-off-white"
        >
          Status lab
        </a>
      </div>
    </div>
  </header>

  <section class="border-b border-border py-16 md:py-20">
    <div class="container-main space-y-10">
      <div>
        <h2 class="font-serif text-2xl text-off-white">Layout options</h2>
        <p class="mt-2 max-w-2xl text-sm text-muted">
          Primary always links to <code class="text-off-white/80">/contact</code>. Secondary is a
          text link — lower commitment for people who need proof first.
        </p>
      </div>

      <HeroCtaLabFrame
        label="Option A — recommended"
        title="Stacked — button then link"
        note="Clearest hierarchy. Primary gets full attention; secondary reads as optional."
        highlight
      >
        <div class="flex flex-col items-start gap-4">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="/work" class="link-arrow">
            See how I work
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </HeroCtaLabFrame>

      <HeroCtaLabFrame
        label="Option B"
        title="Inline row — button + link side by side"
        note="Compact. Works well on desktop; wraps naturally on mobile."
      >
        <div class="flex flex-wrap items-center gap-4 sm:gap-5">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="/work" class="link-arrow">
            See how I work
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </HeroCtaLabFrame>

      <HeroCtaLabFrame
        label="Option C"
        title="Compact primary — shorter button label"
        note="Same stacked layout with a shorter primary label if “workflow call” feels long."
      >
        <div class="flex flex-col items-start gap-4">
          <a href="/contact" class="btn-primary !px-6">Book a call</a>
          <a href="/work" class="link-arrow">
            See how I work
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </HeroCtaLabFrame>

      <HeroCtaLabFrame
        label="Option D"
        title="Secondary as ghost button"
        note="Both actions feel clickable. Slightly heavier — use if you want equal visual weight."
      >
        <div class="flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="/work" class="btn-secondary !px-5 !py-3 text-xs">See how I work</a>
        </div>
      </HeroCtaLabFrame>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-main space-y-10">
      <div>
        <h2 class="font-serif text-2xl text-off-white">Secondary link copy</h2>
        <p class="mt-2 max-w-2xl text-sm text-muted">
          All use Option A layout (stacked). The secondary should match where you send people and
          what question they still have after reading the hero.
        </p>
      </div>

      <HeroCtaLabFrame
        label="Secondary 1 — recommended"
        title="See how I work"
        note="Best for buyers deciding whether to hire you. Sends to /work — process, fit, offerings."
      >
        <div class="flex flex-col items-start gap-4">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="/work" class="link-arrow">
            See how I work
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </HeroCtaLabFrame>

      <HeroCtaLabFrame
        label="Secondary 2"
        title="Who I'm best for"
        note="Good if your main doubt is “is this for me?” Also lands on /work — top section is who you serve."
      >
        <div class="flex flex-col items-start gap-4">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="/work" class="link-arrow">
            Who I'm best for
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </HeroCtaLabFrame>

      <HeroCtaLabFrame
        label="Secondary 3"
        title="What I help with"
        note="Keeps people on the homepage — scrolls to #help. Better for explorers, weaker for conversion."
      >
        <div class="flex flex-col items-start gap-4">
          <a href="/contact" class="btn-primary">Book a workflow call</a>
          <a href="#help-demo" class="link-arrow">
            What I help with
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <p id="help-demo" class="mt-8 rounded-lg border border-dashed border-border px-4 py-3 text-xs text-muted-dim">
          Demo anchor — on the live homepage this would scroll to the help cards section.
        </p>
      </HeroCtaLabFrame>

      <div class="rounded-xl border border-amber-accent/20 bg-charcoal-light/40 p-6 md:p-8">
        <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-amber-accent">Suggestion</p>
        <p class="mt-3 text-base leading-relaxed text-off-white/90">
          <strong class="font-medium text-off-white">Option A</strong> stacked layout +
          <strong class="font-medium text-off-white"> See how I work</strong> secondary. Primary
          converts; secondary qualifies without leaving the “can Michael help us?” thread. Drop or
          keep the scroll chevrons at the bottom of the hero once buttons are live.
        </p>
      </div>
    </div>
  </section>
</Layout>
