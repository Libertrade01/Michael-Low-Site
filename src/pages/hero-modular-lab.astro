---
/**
 * Hero modular-system image lab — 5 attempts from the redesign brief.
 * Live homepage unchanged. Same hero positioning; image only varies.
 */
import Layout from '../components/Layout.astro';

const variants = [
  {
    id: '1',
    label: '01 · Warm seams',
    note: 'Four graphite panels, warm-neutral light in the gaps, pale output sheet on the right.',
    src: '/images/hero-modular-v1.png',
  },
  {
    id: '2',
    label: '02 · Smoked glass',
    note: 'Softer smoked-glass / composite material, lower wall presence, quiet internal glow.',
    src: '/images/hero-modular-v2.png',
  },
  {
    id: '3',
    label: '03 · Architectural resin',
    note: 'More architectural smoked-resin read — calm silhouette, thin resolved layer exiting right.',
    src: '/images/hero-modular-v3.png',
  },
  {
    id: '4',
    label: '04 · Stepped ascent',
    note: 'Panels gently rise left to right; soft blue-gray light in seams; clear hard right edge.',
    src: '/images/hero-modular-v4.png',
  },
  {
    id: '5',
    label: '05 · Soft composite',
    note: 'Finest, most paper-like material; understated gaps; pale output with faint marks.',
    src: '/images/hero-modular-v5.png',
  },
];
---

<Layout
  title="Hero modular image lab — Michael Low"
  description="Five modular-system hero image attempts. Live site unchanged."
>
  <div class="lab">
    <aside class="lab-bar" role="note">
      <div class="lab-bar__inner">
        <p>
          <strong>Hero modular lab</strong> — five image attempts from your brief. Same hero layout/positioning. Live site untouched.
        </p>
        <a href="/">← Live homepage</a>
      </div>
    </aside>

    <nav class="lab-nav" aria-label="Image variants">
      <div class="lab-nav__inner">
        {variants.map((variant) => (
          <a href={`#hero-${variant.id}`}>{variant.label}</a>
        ))}
      </div>
    </nav>

    {variants.map((variant) => (
      <section class="lab-block" id={`hero-${variant.id}`}>
        <header class="lab-block__meta">
          <h2>{variant.label}</h2>
          <p>{variant.note}</p>
        </header>

        <div class="hero">
          <div class="hero__shell hero__stage">
            <div class="hero__copy">
              <p class="hero__kicker">Product design · AI · Automation</p>
              <h1>Practical AI<br />systems<br />for messy<br />workflows.</h1>
              <p class="hero__intro">
                I design and build AI-powered products, knowledge systems and automation that make complex work simpler.
              </p>
              <div class="hero__actions">
                <a class="hero__button" href="/#systems">Explore the systems</a>
                <a class="hero__link" href="/#process">How I work <span aria-hidden="true">↓</span></a>
              </div>
            </div>

            <figure class="hero__visual">
              <img
                src={`${variant.src}?v=1`}
                alt="Modular graphite system emerging from translucent layers"
                width="1376"
                height="768"
                loading="lazy"
                decoding="async"
              />
            </figure>
          </div>

          <div class="hero__shell hero__foot">
            <span>Based in São Paulo · Working globally</span>
            <span>Open to AI product &amp; systems roles</span>
          </div>
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  :global(.site-nav),
  :global(.site-footer-v2) {
    display: none;
  }

  .lab {
    --paper: #f4f0e8;
    --ink: #1d1f1e;
    --soft: #454744;
    --muted: #77756f;
    --line: rgba(48, 47, 43, 0.14);
    color: var(--ink);
    background: #e7e1d6;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  .lab a {
    text-decoration: none;
  }

  .lab-bar {
    background: #202220;
    color: #f4f0e8;
  }

  .lab-bar__inner {
    width: min(92rem, calc(100% - 3rem));
    margin-inline: auto;
    min-height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.78rem;
  }

  .lab-bar p {
    margin: 0;
    color: color-mix(in srgb, #f4f0e8 78%, transparent);
  }

  .lab-bar strong {
    color: #f4f0e8;
    font-weight: 500;
  }

  .lab-bar a {
    color: #f4f0e8;
    border-bottom: 1px solid color-mix(in srgb, #f4f0e8 35%, transparent);
    white-space: nowrap;
  }

  .lab-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(14px);
  }

  .lab-nav__inner {
    width: min(92rem, calc(100% - 3rem));
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
    padding-block: 0.85rem;
  }

  .lab-nav a {
    color: var(--soft);
    font-size: 0.78rem;
    font-weight: 500;
  }

  .lab-nav a:hover {
    color: var(--ink);
  }

  .lab-block {
    padding: 2rem 0 3.5rem;
  }

  .lab-block__meta {
    width: min(92rem, calc(100% - 3rem));
    margin: 0 auto 1.25rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem 2rem;
    align-items: end;
  }

  .lab-block__meta h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .lab-block__meta p {
    margin: 0;
    max-width: 46rem;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100svh - 8rem);
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .hero__shell {
    width: min(92rem, calc(100% - 3rem));
    margin-inline: auto;
  }

  .hero__stage {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    padding-block: clamp(3.5rem, 7vh, 6rem);
  }

  .hero__kicker {
    margin: 0;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__copy {
    position: relative;
    z-index: 3;
    max-width: 34rem;
  }

  .hero h1 {
    margin: 1.25rem 0 0;
    font-size: clamp(3rem, 5.7vw, 5.7rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .hero__intro {
    max-width: 34rem;
    margin: 1.8rem 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    font-weight: 300;
    line-height: 1.65;
    text-wrap: balance;
  }

  .hero__intro,
  .hero__actions {
    position: relative;
    background: linear-gradient(90deg, var(--paper) 72%, transparent);
    padding-right: 1.5rem;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.35rem;
    margin-top: 2.25rem;
  }

  .hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.75rem 1.15rem;
    border-radius: 0.35rem;
    color: var(--paper) !important;
    background: var(--ink);
    font-size: 0.84rem;
    font-weight: 500;
    box-shadow: 0 8px 22px rgba(31, 31, 28, 0.12);
  }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--soft) !important;
    font-size: 0.84rem;
  }

  /* Same positioning as live homepage hero graphic */
  .hero__visual {
    position: absolute;
    left: 16%;
    right: 2%;
    top: 44%;
    height: min(72vh, 38rem);
    transform: translateY(-46%);
    margin: 0;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .hero__visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: none;
    height: 112%;
    display: block;
    margin: 0;
    object-fit: contain;
    object-position: right center;
    transform: translate(-6%, -5%) scale(1.08);
    mix-blend-mode: multiply;
    opacity: 0.94;
    -webkit-mask-image:
      linear-gradient(90deg, transparent 0%, #000 10%, #000 100%),
      linear-gradient(180deg, transparent 0%, #000 10%, #000 88%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(90deg, transparent 0%, #000 10%, #000 100%),
      linear-gradient(180deg, transparent 0%, #000 10%, #000 88%, transparent 100%);
    mask-composite: intersect;
  }

  .hero__foot {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
    margin-top: auto;
    color: var(--muted);
    border-top: 1px solid var(--line);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .lab-block__meta {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .hero__visual {
      left: 8%;
      right: 0;
      top: auto;
      bottom: 12%;
      height: 18rem;
      transform: none;
    }

    .hero__visual img {
      transform: none;
      height: 100%;
    }
  }

  @media (max-width: 680px) {
    .hero h1 {
      font-size: clamp(2.7rem, 12vw, 4rem);
    }

    .hero__stage {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__visual {
      position: relative;
      left: auto;
      right: auto;
      top: auto;
      bottom: auto;
      width: 100%;
      height: 14rem;
      margin-top: 1.5rem;
    }

    .hero__intro,
    .hero__actions {
      background: none;
      padding-right: 0;
    }

    .hero__foot {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
