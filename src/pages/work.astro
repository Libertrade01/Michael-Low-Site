---
import Layout from '../components/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import FeatureList from '../components/FeatureList.astro';
import AvailabilityBanner from '../components/AvailabilityBanner.astro';
import StatusLine from '../components/StatusLine.astro';
import { workPage, engagementProcess, notOffered } from '../config/site';

const workH2 = 'font-sans text-3xl font-semibold tracking-tight text-off-white md:text-4xl md:leading-tight';
const workBullet = 'shrink-0 font-sans text-amber-accent';
---

<Layout
  title="Work With Me — Michael Low"
  description="AI workflow audits, build sprints, knowledge systems, and practical implementation for small teams."
>
  <PageHeader title="Work with me" subtitle={workPage.intro} />

  <section class="border-b border-border py-8">
    <div class="container-main max-w-3xl">
      <StatusLine variant="caption" />
    </div>
  </section>

  <section class="section-padding border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>Who I'm best for</h2>
      <p class="mt-4 text-base leading-relaxed text-muted md:text-lg">{workPage.whoBestFor.lead}</p>
      <p class="mt-6 text-base text-muted">You probably have:</p>
      <ul class="mt-3 space-y-2">
        {
          workPage.whoBestFor.bullets.map((item) => (
            <li class="flex gap-3 text-base leading-relaxed text-muted">
              <span class={workBullet} aria-hidden="true">−</span>
              {item}
            </li>
          ))
        }
      </ul>
      <p class="mt-6 text-base leading-relaxed text-off-white/90 md:text-lg">{workPage.whoBestFor.close}</p>
    </div>
  </section>

  <section class="section-padding section-band-sand border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>Best fit if</h2>
      <ul class="mt-6 space-y-3">
        {
          workPage.bestFitIf.map((item) => (
            <li class="flex gap-3 text-base leading-relaxed text-muted md:text-lg">
              <span class={workBullet} aria-hidden="true">−</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section-padding border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>Ways I can help</h2>
      <p class="mb-8 mt-2 text-base text-muted md:text-lg">Pick a starting point — most projects begin with an audit or a single build sprint.</p>
      <FeatureList features={[...workPage.offerings]} />
    </div>
  </section>

  <section class="section-padding section-band-sand border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>How it works</h2>
      <div class="mt-8 space-y-8">
        {
          engagementProcess.map((step, i) => (
            <div class="flex gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-amber-accent/40 font-mono text-xs text-amber-accent">
                {i + 1}
              </span>
              <div>
                <h3 class="font-sans text-lg font-semibold text-off-white">{step.step}</h3>
                <p class="mt-1 text-base leading-relaxed text-muted">{step.detail}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-padding border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>What you get</h2>
      <ul class="mt-6 space-y-3">
        {
          workPage.whatYouGet.map((item) => (
            <li class="flex gap-3 text-base leading-relaxed text-muted md:text-lg">
              <span class={workBullet} aria-hidden="true">−</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section-padding section-band-sand border-b border-border">
    <div class="container-main max-w-3xl">
      <h2 class={workH2}>What I don't do</h2>
      <ul class="mt-6 space-y-3">
        {
          notOffered.map((item) => (
            <li class="flex gap-3 text-base leading-relaxed text-muted md:text-lg">
              <span class={workBullet} aria-hidden="true">—</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-main max-w-2xl">
      <AvailabilityBanner />
      <p class="mt-8 text-center">
        <a href="/contact" class="link-arrow">
          Start with a workflow call
          <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </section>
</Layout>
