---

import Layout from '../components/Layout.astro';

import Hero from '../components/Hero.astro';

import SectionHeader from '../components/SectionHeader.astro';

import ProjectCard from '../components/ProjectCard.astro';

import AvailabilityBanner from '../components/AvailabilityBanner.astro';

import { getFeaturedProjects } from '../utils/content';



const featured = await getFeaturedProjects();

---



<Layout>

  <Hero />



  <section id="portfolio" class="section-padding relative">

    <div

      class="pointer-events-none absolute inset-0 opacity-50"

      style="background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(var(--accent-rgb),0.06), transparent);"

      aria-hidden="true"

    >

    </div>

    <div class="container-main relative">

      <SectionHeader

        label="Portfolio"

        title="Systems I've built"

        subtitle="Products and workflows that turn messy inputs into structured, reusable output."

      />

      <div class="grid gap-8 md:grid-cols-2">

        {featured.map((project, i) => <ProjectCard project={project} index={i} />)}

      </div>

      <a href="/projects" class="link-arrow mt-12">

        All projects

        <span aria-hidden="true">→</span>

      </a>

    </div>

  </section>



  <section class="section-padding">

    <div class="container-main max-w-3xl">

      <SectionHeader

        label="Contact"

        title="Interested in working together?"

        subtitle="AI workflows, automation systems, research pipelines, or content operations."

      />

      <AvailabilityBanner />

    </div>

  </section>

</Layout>

