---
import Layout from '../components/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../config/site';

const links = [
  { index: '01', label: 'Email', value: site.email, href: `mailto:${site.email}`, external: false },
  { index: '02', label: 'LinkedIn', value: 'Connect on LinkedIn', href: site.linkedin, external: true },
  { index: '03', label: 'GitHub', value: 'See the work behind the systems', href: site.github, external: true },
];
---

<Layout title={`Contact — ${site.name}`} description="Talk to Michael Low about a practical AI system, product, or information-heavy workflow.">
  <div class="inner-v2 contact-v2">
    <PageHeader
      label="Contact"
      title="Let’s make the messy part clearer."
      subtitle="If you have an information-heavy workflow that is held together by tabs, memory and repeated manual work, tell me what is happening."
    />
    <section class="contact-v2__body">
      <div class="home-v2-shell contact-v2__layout">
        <div class="contact-v2__status">
          <p class="home-v2-kicker">Current availability</p>
          <p><span aria-hidden="true"></span>{site.availability}</p>
        </div>
        <div class="contact-v2__links">
          {links.map((link) => (
            <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              <span>{link.index}</span>
              <div><small>{link.label}</small><strong>{link.value}</strong></div>
              <i aria-hidden="true">↗</i>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
