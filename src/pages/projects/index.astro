---
import Layout from '../../components/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import EditorialProjectCard from '../../components/EditorialProjectCard.astro';
import { getFeaturedProjects } from '../../utils/content';

const projects = await getFeaturedProjects();
---

<Layout title="Systems I’ve built — Michael Low" description="Products, operating systems, and AI workflows designed and built by Michael Low.">
  <div class="inner-v2">
    <PageHeader
      label="Selected work"
      title="Systems I’ve built"
      subtitle="Products and workflows that turn scattered information into something people can understand, operate and improve."
    />
    <section class="inner-v2-section">
      <div class="home-v2-shell home-v2-system-list">
        {projects.map((project, index) => <EditorialProjectCard project={project} index={index} />)}
      </div>
    </section>
  </div>
</Layout>
