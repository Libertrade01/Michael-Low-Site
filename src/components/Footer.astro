---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="site-footer-v2">
  <div class="site-footer-v2__inner">
    <div class="site-footer-v2__main">
      <div>
        <a href="/" class="site-footer-v2__name">{site.name}</a>
        <p>{site.shortBio}</p>
      </div>

      <nav aria-label="Footer navigation">
        <a href="/projects">Systems</a>
        <a href="/about">About</a>
        <a href="/build-log">Notes</a>
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
        <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </nav>
    </div>

    <p class="site-footer-v2__meta">© {year} {site.name}</p>
  </div>
</footer>

<style>
  .site-footer-v2 {
    --foot-paper: var(--ml-paper, #f4f0e8);
    --foot-ink: var(--ml-ink, #1d1f1e);
    --foot-soft: var(--ml-ink-soft, #454744);
    --foot-muted: var(--ml-muted, #77756f);
    --foot-line: var(--ml-line, rgba(48, 47, 43, 0.14));
    --foot-shell: var(--ml-shell, min(92rem, calc(100% - 3rem)));
    color: var(--foot-ink);
    background: var(--foot-paper);
    border-top: 1px solid var(--foot-line);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  .site-footer-v2__inner {
    width: var(--foot-shell);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.25rem);
  }

  .site-footer-v2__main {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .site-footer-v2__name {
    color: var(--foot-ink);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
  }

  .site-footer-v2 p {
    margin: 0.7rem 0 0;
    color: var(--foot-muted);
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.6;
  }

  .site-footer-v2 nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.4rem;
    justify-content: flex-end;
  }

  .site-footer-v2 nav a {
    color: var(--foot-soft);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .site-footer-v2 nav a:hover {
    color: var(--foot-ink);
  }

  .site-footer-v2__meta {
    margin: 0;
    padding-top: 1.15rem;
    border-top: 1px solid var(--foot-line);
    color: var(--foot-muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: right;
    line-height: 1.4;
  }

  @media (max-width: 980px) {
    .site-footer-v2__inner {
      width: min(100% - 2rem, 60rem);
    }

    .site-footer-v2__main {
      grid-template-columns: 1fr;
    }

    .site-footer-v2 nav {
      justify-content: flex-start;
    }

    .site-footer-v2__meta {
      text-align: left;
    }
  }
</style>
