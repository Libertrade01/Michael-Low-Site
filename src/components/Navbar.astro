---
import { site } from '../config/site';
---

<header class="site-nav" data-site-nav>
  <nav class="site-nav__inner" aria-label="Primary navigation">
    <a class="site-nav__name" href="/">{site.name}</a>

    <div class="site-nav__links">
      <a href="/#systems">Systems</a>
      <a href="/#about">About</a>
      <a href="/#process">How I work</a>
      <a href="/build-log">Notes</a>
    </div>

    <div class="site-nav__actions">
      <span class="site-nav__availability"><i aria-hidden="true"></i>Open to AI roles</span>
      <details class="site-nav__menu">
        <summary>Menu</summary>
        <div>
          <a href="/#systems">Systems</a>
          <a href="/#about">About</a>
          <a href="/#process">How I work</a>
          <a href="/about">Full about</a>
          <a href="/build-log">Notes</a>
          <a href="/#contact">Contact</a>
        </div>
      </details>
    </div>
  </nav>
</header>

<style>
  .site-nav {
    --nav-paper: var(--ml-paper, #f4f0e8);
    --nav-ink: var(--ml-ink, #1d1f1e);
    --nav-soft: var(--ml-ink-soft, #454744);
    --nav-muted: var(--ml-muted, #77756f);
    --nav-line: var(--ml-line, rgba(48, 47, 43, 0.14));
    --nav-line-strong: var(--ml-line-strong, rgba(48, 47, 43, 0.24));
    --nav-shell: var(--ml-shell, min(92rem, calc(100% - 3rem)));
    position: sticky;
    top: 0;
    z-index: 60;
    background: color-mix(in srgb, var(--nav-paper) 88%, transparent);
    border-bottom: 1px solid var(--nav-line);
    backdrop-filter: blur(18px) saturate(120%);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  .site-nav__inner {
    width: var(--nav-shell);
    min-height: 6.4rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .site-nav__name {
    justify-self: start;
    color: var(--nav-ink);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.25rem;
  }

  .site-nav__links a,
  .site-nav__menu a {
    color: var(--nav-soft);
    font-size: 0.94rem;
    text-decoration: none;
  }

  .site-nav__links a:hover,
  .site-nav__menu a:hover {
    color: var(--nav-ink);
  }

  .site-nav__actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .site-nav__availability {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--nav-muted);
    font-size: 0.86rem;
    white-space: nowrap;
  }

  .site-nav__availability i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: #638067;
    box-shadow: 0 0 0 3px rgba(99, 128, 103, 0.1);
  }

  .site-nav__menu {
    display: none;
    position: relative;
  }

  .site-nav__menu summary {
    color: var(--nav-ink);
    font-size: 0.8rem;
    cursor: pointer;
    list-style: none;
  }

  .site-nav__menu summary::-webkit-details-marker {
    display: none;
  }

  .site-nav__menu > div {
    position: absolute;
    top: 2.2rem;
    right: 0;
    min-width: 12rem;
    display: grid;
    padding: 0.7rem;
    background: var(--ml-paper-raised, #faf7f1);
    border: 1px solid var(--nav-line);
    box-shadow: 0 18px 50px rgba(32, 30, 25, 0.12);
  }

  .site-nav__menu a {
    padding: 0.7rem 0.8rem;
  }

  @media (max-width: 980px) {
    .site-nav__inner {
      grid-template-columns: 1fr auto;
      width: min(100% - 2rem, 60rem);
    }

    .site-nav__links,
    .site-nav__availability {
      display: none;
    }

    .site-nav__menu {
      display: block;
    }
  }
</style>
