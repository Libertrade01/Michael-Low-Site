---
interface Props {
  title: string;
  description: string;
  index?: number;
}

const { title, description, index = 0 } = Astro.props;
const moduleNum = String(index + 1).padStart(2, '0');
---

<article class="help-module-card group">
  <div class="help-module-card__accent" aria-hidden="true"></div>
  <header class="help-module-card__head">
    <span class="help-module-card__index font-mono">[{moduleNum}]</span>
    <h3 class="help-module-card__title">{title}</h3>
  </header>
  <p class="help-module-card__desc">{description}</p>
</article>
