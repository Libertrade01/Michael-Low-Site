---
interface BriefSection {
  title: string;
  lead: string;
  items?: string[];
  note?: string;
}

interface Screenshot {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  overview: BriefSection;
  problem: BriefSection;
  solution: BriefSection;
  build: BriefSection;
  results: BriefSection;
  screenshot?: Screenshot;
}

const { overview, problem, solution, build, results, screenshot } = Astro.props;

const sections = [
  { key: 'overview', index: '01', data: overview },
  { key: 'problem', index: '02', data: problem },
  { key: 'solution', index: '03', data: solution },
  { key: 'build', index: '04', data: build },
  { key: 'results', index: '05', data: results },
] as const;
---

<div class="project-brief">
  {
    sections.map((section) => (
      <section class={`project-brief__section project-brief__section--${section.key}`} aria-labelledby={`brief-${section.key}-title`}>
        <header class="project-brief__head">
          <p class="project-brief__index">
            <span aria-hidden="true">{section.index}</span>
            {section.data.title}
          </p>
          <h2 id={`brief-${section.key}-title`}>{section.data.lead}</h2>
        </header>

        {
          section.data.items && section.data.items.length > 0 && (
            <ul class="project-brief__list" role="list">
              {section.data.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )
        }

        {section.data.note && <p class="project-brief__note">{section.data.note}</p>}

        {
          section.key === 'solution' && screenshot && (
            <figure class="project-brief__shot">
              <img src={screenshot.src} alt={screenshot.alt} loading="lazy" decoding="async" />
              {screenshot.caption && <figcaption>{screenshot.caption}</figcaption>}
            </figure>
          )
        }
      </section>
    ))
  }
</div>

<style>
  .project-brief {
    display: grid;
    gap: clamp(3.25rem, 7vw, 5.5rem);
    width: min(100%, 46rem);
    margin-inline: auto;
  }

  .project-brief__head {
    margin-bottom: 1.15rem;
  }

  .project-brief__index {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0;
    color: var(--ml-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-brief__index span {
    color: var(--ml-ink);
  }

  .project-brief__section h2 {
    margin: 0.7rem 0 0;
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: clamp(1.55rem, 3vw, 2.35rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.12;
    text-wrap: balance;
  }

  .project-brief__list {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
    border-left: 1px solid var(--ml-line-strong, var(--ml-line));
    padding-left: 1rem;
  }

  .project-brief__list li {
    color: var(--ml-ink-soft, var(--ml-muted));
    font-size: clamp(0.95rem, 1.15vw, 1.05rem);
    font-weight: 300;
    line-height: 1.55;
  }

  .project-brief__note {
    margin: 1.15rem 0 0;
    color: var(--ml-muted);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.6;
  }

  .project-brief__shot {
    margin: 1.75rem 0 0;
  }

  .project-brief__shot img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.4rem;
    box-shadow:
      inset 0 0 0 1px rgba(48, 47, 43, 0.08),
      0 0.8rem 2rem rgba(48, 47, 43, 0.06);
    background: #0a0a0a;
  }

  .project-brief__shot figcaption {
    margin-top: 0.7rem;
    color: var(--ml-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
