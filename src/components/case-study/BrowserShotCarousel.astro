---
interface Shot {
  image: string;
  alt: string;
  label?: string;
}

interface Props {
  shots: Shot[];
  frameLabel?: string;
  idPrefix?: string;
}

const { shots, frameLabel = 'libertrade.app', idPrefix = 'loop-frame' } = Astro.props;
const hasMultipleShots = shots.length > 1;
---

{
  shots.length > 0 && (
    <figure
      class="browser-shot-carousel"
      data-snapshot-carousel
      aria-label="Product loop walkthrough"
    >
      <div class="product-frame__bar" aria-hidden="true">
        <span class="product-frame__dots"><i></i><i></i><i></i></span>
        <span class="product-frame__label">{frameLabel}</span>
        <span></span>
      </div>

      <div
        class="browser-shot-carousel__track"
        tabindex={hasMultipleShots ? 0 : undefined}
        data-snapshot-track
      >
        {shots.map((shot, index) => (
          <div class="browser-shot-carousel__slide" id={`${idPrefix}-${index + 1}`} data-snapshot-slide>
            <img src={shot.image} alt={shot.alt} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
            {shot.label && (
              <p class="browser-shot-carousel__caption">
                <span>{String(index + 1).padStart(2, '0')}</span>
                {shot.label}
              </p>
            )}
          </div>
        ))}
      </div>

      {hasMultipleShots && (
        <nav class="browser-shot-carousel__nav" aria-label="Loop screen navigation">
          {shots.map((shot, index) => (
            <a
              href={`#${idPrefix}-${index + 1}`}
              aria-current={index === 0 ? 'true' : undefined}
              aria-label={`View ${shot.label ?? `screen ${index + 1}`}`}
              data-snapshot-indicator
            >
              <span>{String(index + 1).padStart(2, '0')}</span>
            </a>
          ))}
        </nav>
      )}
    </figure>
  )
}

<style>
  .browser-shot-carousel {
    background: #e9e7e1;
    border: 1px solid rgba(48, 47, 43, 0.22);
    border-radius: 0.55rem;
    box-shadow: 0 0.8rem 2rem rgba(48, 47, 43, 0.08);
    margin: 2rem 0 0;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .product-frame__bar {
    align-items: center;
    background: rgba(48, 47, 43, 0.035);
    border-bottom: 1px solid rgba(48, 47, 43, 0.14);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 2rem;
    padding: 0 0.75rem;
  }

  .product-frame__dots {
    display: flex;
    gap: 0.3rem;
  }

  .product-frame__dots i {
    background: rgba(48, 47, 43, 0.28);
    border-radius: 50%;
    display: block;
    height: 0.38rem;
    width: 0.38rem;
  }

  .product-frame__label {
    color: var(--ml-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .browser-shot-carousel__track {
    display: flex;
    gap: 0;
    max-width: 100%;
    min-width: 0;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .browser-shot-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .browser-shot-carousel__track:focus-visible {
    outline: 2px solid var(--ml-line-strong, var(--ml-line));
    outline-offset: -2px;
  }

  .browser-shot-carousel__slide {
    box-sizing: border-box;
    flex: 0 0 100%;
    margin: 0;
    max-width: 100%;
    min-width: 0;
    scroll-snap-align: start;
    width: 100%;
  }

  .browser-shot-carousel__slide img {
    background: #0a0a0a;
    border-radius: 0;
    box-shadow: none;
    display: block;
    height: auto;
    width: 100%;
  }

  .browser-shot-carousel__caption {
    align-items: center;
    color: var(--ml-muted);
    display: flex;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    gap: 0.7rem;
    letter-spacing: 0.06em;
    line-height: 1.5;
    margin: 0;
    padding: 0.75rem 0.85rem 0.15rem;
    text-transform: uppercase;
  }

  .browser-shot-carousel__caption span {
    color: var(--ml-ink);
  }

  .browser-shot-carousel__nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
    padding: 0.55rem 0.75rem 0.85rem;
  }

  .browser-shot-carousel__nav a {
    align-items: center;
    border: 1px solid var(--ml-line);
    border-radius: 999px;
    color: var(--ml-muted);
    display: inline-flex;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    height: 1.8rem;
    justify-content: center;
    letter-spacing: 0.08em;
    min-width: 2.4rem;
    text-decoration: none;
  }

  .browser-shot-carousel__nav a:hover,
  .browser-shot-carousel__nav a:focus-visible,
  .browser-shot-carousel__nav a[aria-current='true'] {
    background: var(--ml-ink);
    border-color: var(--ml-ink);
    color: #f7f6f1;
  }
</style>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-snapshot-carousel]');

  carousels.forEach((carousel) => {
    if (carousel.dataset.snapshotCarouselEnhanced === 'true') return;

    const track = carousel.querySelector<HTMLElement>('[data-snapshot-track]');
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-snapshot-slide]'));
    const indicators = Array.from(carousel.querySelectorAll<HTMLElement>('[data-snapshot-indicator]'));

    if (!track || slides.length < 2 || indicators.length === 0) return;

    carousel.dataset.snapshotCarouselEnhanced = 'true';

    const setActiveIndicator = (activeIndex: number) => {
      indicators.forEach((indicator, index) => {
        if (index === activeIndex) {
          indicator.setAttribute('aria-current', 'true');
        } else {
          indicator.removeAttribute('aria-current');
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const activeIndex = slides.indexOf(entry.target as HTMLElement);
          if (activeIndex >= 0) setActiveIndicator(activeIndex);
        });
      },
      { root: track, threshold: 0.62 },
    );

    slides.forEach((slide) => observer.observe(slide));
  });
</script>
