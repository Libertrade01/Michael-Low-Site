---

import { hero } from '../config/site';



interface Props {

  large?: boolean;

  variant?: 'default' | 'hero' | 'large';

  filename?: string;

}



const { large = false, variant, filename = hero.terminal.filename } = Astro.props;

const isLarge = variant === 'large' || (variant == null && large);

const isHero = variant === 'hero';

const { lines } = hero.terminal;

---



<div

  class:list={[

    'terminal-panel relative overflow-hidden rounded-2xl border border-border bg-charcoal glow-amber',

    isLarge && 'rounded-3xl',

    isHero && 'rounded-2xl',

  ]}

>

  <div

    class:list={[

      'terminal-titlebar flex items-center gap-2 border-b border-border bg-charcoal-light/80 px-4',

      isLarge ? 'py-3' : isHero ? 'py-3.5' : 'py-2.5',

    ]}

  >

    <span class="h-2.5 w-2.5 rounded-full bg-black/10"></span>

    <span class="h-2.5 w-2.5 rounded-full bg-black/10"></span>

    <span class="h-2.5 w-2.5 rounded-full bg-black/10"></span>

    <span

      class:list={[

        'terminal-filename ml-2 font-mono text-muted',

        isLarge ? 'text-xs' : isHero ? 'text-xs' : 'text-[10px]',

      ]}>{filename}</span

    >

  </div>

  <div

    class:list={[

      'font-mono leading-relaxed',

      isLarge

        ? 'px-6 py-8 text-base md:text-lg lg:text-xl'

        : isHero

          ? 'px-7 py-9 text-base md:text-lg lg:px-8 lg:py-10 lg:text-xl'

          : 'px-4 py-4 text-[11px]',

    ]}

  >

    <div class:list={[isLarge ? 'space-y-3' : isHero ? 'space-y-3.5 md:space-y-4' : 'space-y-2']}>

      {

        lines.map((line) => (

          <p class:list={[line.arrow && (isLarge || isHero ? 'pt-1' : 'pt-0.5')]}>

            {line.arrow && <span class="terminal-arrow">→ </span>}

            <span class="terminal-subject">{line.subject}</span><span class="terminal-method">.{line.method}()</span>

            {line.arrow && (

              <span

                class:list={[

                  'ml-1 inline-block animate-[blink_1s_step-end_infinite] bg-amber-accent',

                  isLarge ? 'h-5 w-2' : isHero ? 'h-4 w-1.5' : 'h-3.5 w-1.5',

                ]}

                aria-hidden="true"

              />

            )}

          </p>

        ))

      }

    </div>

  </div>

  <div

    class="pointer-events-none absolute -inset-px rounded-[inherit] opacity-60"

    style="background: radial-gradient(ellipse at 50% 100%, rgba(var(--accent-rgb),0.12), transparent 65%);"

    aria-hidden="true"

  >

  </div>

</div>


