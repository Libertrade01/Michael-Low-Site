---
interface Props {
  questions: string[];
}

const { questions } = Astro.props;
---

<ol class="my-7 list-none space-y-4 md:my-8 md:space-y-5" role="list">
  {
    questions.map((question, i) => (
      <li class="flex gap-4 md:gap-5">
        <span
          class="shrink-0 pt-0.5 font-mono text-[11px] tabular-nums tracking-wide text-amber-accent/45"
          aria-hidden="true"
        >
          {String(i + 1).padStart(2, '0')}
        </span>
        <p class="min-w-0 text-sm leading-relaxed text-muted md:text-[15px]">{question}</p>
      </li>
    ))
  }
</ol>
