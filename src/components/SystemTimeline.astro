---
interface Phase {
  title: string;
  steps: string[];
}

interface Props {
  phases: Phase[];
  footnote?: string;
}

const { phases, footnote } = Astro.props;
---

<div class="my-2 space-y-5">
  {
    phases.map((phase) => (
      <div class="border-l-2 border-amber-accent/35 pl-5 md:pl-6">
        <h3 class="text-[15px] font-medium tracking-tight text-off-white md:text-base">
          {phase.title}
        </h3>
        {
          phase.steps.length > 0 && (
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">
              {phase.steps.join(' ')}
            </p>
          )
        }
      </div>
    ))
  }

  {
    footnote && (
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">{footnote}</p>
    )
  }
</div>
