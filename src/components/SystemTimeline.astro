---
interface Phase {
  title: string;
  steps: string[];
}

interface Props {
  phases: Phase[];
  footnote?: string;
}

const { phases, footnote } = Astro.props;
---

<div class="my-2">
  <ol class="relative list-none space-y-0 pl-8 md:pl-10" role="list">
    <div
      class="pointer-events-none absolute bottom-3 left-[5px] top-3 w-px bg-amber-accent/20 md:left-[7px]"
      aria-hidden="true"
    />

    {
      phases.map((phase, i) => (
        <li class:list={['relative', i < phases.length - 1 && 'pb-10 md:pb-12']}>
          <span
            class="absolute -left-8 top-1.5 box-border h-2.5 w-2.5 rounded-full border border-amber-accent/45 bg-charcoal ring-2 ring-charcoal md:-left-10"
            aria-hidden="true"
          />
          <h3 class="text-base font-medium tracking-tight text-off-white md:text-[17px]">
            {phase.title}
          </h3>
          <ul class="mt-3 list-none space-y-2" role="list">
            {phase.steps.map((step) => (
              <li class="text-sm leading-relaxed text-muted">{step}</li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>

  {
    footnote && (
      <p class="mt-8 max-w-2xl text-sm leading-relaxed text-muted">{footnote}</p>
    )
  }
</div>
