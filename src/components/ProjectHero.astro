---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import StatusBadge from './StatusBadge.astro';
import TechStack from './TechStack.astro';
import type { ProjectEntry } from '../utils/content';

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const { title, description, descriptionExtra, status, stack, role, github, liveUrl, coverImage } =
  project.data;

const coverRetina = coverImage?.replace(/\.(png|jpe?g|webp)$/i, '@2x.$1');
const hasRetinaCover =
  Boolean(coverImage && coverRetina) &&
  existsSync(join(process.cwd(), 'public', coverRetina!.replace(/^\//, '')));
---

<header class="relative overflow-hidden border-b border-border pt-16 pb-8 md:pt-24 md:pb-10">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% -20%, rgba(var(--accent-rgb),0.12), transparent);"
    aria-hidden="true"
  >
  </div>
  <div class="container-main relative">
    <div class="flex flex-wrap items-center gap-3">
      <StatusBadge status={status} />
      <span class="font-mono text-[10px] uppercase tracking-widest text-muted">{role}</span>
    </div>
    <h1 class="mt-6 max-w-4xl font-serif text-4xl text-off-white md:text-6xl md:leading-tight">{title}</h1>
    <p class="mt-5 max-w-5xl text-base leading-relaxed text-muted sm:text-lg">
      {description}{descriptionExtra ? ` ${descriptionExtra}` : ''}
    </p>

    {
      liveUrl && (
        <div class="mt-8">
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="demo-cta group inline-flex w-full max-w-xl flex-col gap-1 rounded-xl border border-amber-accent/45 bg-amber-accent/12 px-8 py-5 shadow-[0_0_40px_rgba(var(--accent-rgb),0.12)] transition hover:border-amber-accent hover:bg-amber-accent/20 sm:w-auto"
          >
            <span class="flex items-center gap-3 font-mono text-sm font-medium uppercase tracking-[0.14em] text-off-white md:text-base">
              Open live demo
              <span class="text-amber-accent transition-transform group-hover:translate-x-1" aria-hidden="true">
                →
              </span>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-muted">
              Interactive portfolio demo
            </span>
          </a>
        </div>
      )
    }

    <div class="mt-8">
      <TechStack stack={stack} />
    </div>
    {
      github && (
        <div class="mt-6">
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs uppercase tracking-wider text-muted hover:text-amber-accent"
          >
            View source on GitHub →
          </a>
        </div>
      )
    }
    {
      coverImage && (
        <div class="mt-12 overflow-hidden rounded-2xl border border-border glow-amber">
          {
            hasRetinaCover ? (
              <picture>
                <source srcset={`${coverRetina} 2x`} type="image/png" />
                <img
                  src={coverImage}
                  srcset={`${coverImage} 1x, ${coverRetina} 2x`}
                  alt={`${title} cover`}
                  class="h-auto w-full"
                  loading="eager"
                  decoding="async"
                  sizes="(min-width: 1152px) 1152px, 100vw"
                />
              </picture>
            ) : (
              <img
                src={coverImage}
                alt={`${title} cover`}
                class="h-auto w-full"
                loading="eager"
                decoding="async"
              />
            )
          }
        </div>
      )
    }
  </div>
</header>
