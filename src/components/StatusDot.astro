---
interface Props {
  color?: 'blue' | 'green';
  /** Quieter dot for captions — no ping, smaller, softer */
  subtle?: boolean;
}

const { color = 'blue', subtle = false } = Astro.props;

const ping = color === 'blue' ? 'bg-blue-400' : 'bg-emerald-400';
const dot = color === 'blue' ? 'bg-blue-500' : 'bg-emerald-500';
const subtleDot = color === 'blue' ? 'bg-blue-400/55' : 'bg-emerald-400/55';
---

{
  subtle ? (
    <span
      class:list={['inline-flex shrink-0 rounded-full', subtleDot, 'h-1.5 w-1.5']}
      aria-hidden="true"
    />
  ) : (
    <span class="relative flex h-2 w-2">
      <span class:list={['absolute inline-flex h-full w-full animate-ping rounded-full opacity-60', ping]} />
      <span class:list={['relative inline-flex h-2 w-2 rounded-full', dot]} />
    </span>
  )
}
