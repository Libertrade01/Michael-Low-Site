---
interface Props {
  status: 'Built' | 'Prototype' | 'In Progress' | 'Concept';
}

const { status } = Astro.props;

const styles: Record<Props['status'], string> = {
  Built: 'border-[#047857] bg-[#e8f5f0] text-[#047857]',
  Prototype: 'border-[#2a7a7e] bg-[#e8f4f4] text-[#2a7a7e]',
  'In Progress': 'border-[#1f344a]/35 bg-[#eef1f4] text-[#1f344a]',
  Concept: 'border-[#d8d4ca] bg-[#f0ebe3] text-[#6b7280]',
};
---

<span
  class:list={[
    'inline-flex rounded-full border px-2.5 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wider',
    styles[status],
  ]}
>
  {status}
</span>
