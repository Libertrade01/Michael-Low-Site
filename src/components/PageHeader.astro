---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  compact?: boolean;
  tightSubtitle?: boolean;
}

const { title, subtitle, label = 'Index', compact = false, tightSubtitle = false } = Astro.props;
---

<header class:list={['page-header-v2', compact && 'page-header-v2--compact']}>
  <div class="page-header-v2__inner">
    <p class="home-v2-kicker">{label}</p>
    <h1>{title}</h1>
    {subtitle && <p class:list={['page-header-v2__subtitle', tightSubtitle && 'page-header-v2__subtitle--tight']}>{subtitle}</p>}
  </div>
</header>
