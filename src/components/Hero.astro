---
import { hero } from '../config/site';
import MessyWord from './MessyWord.astro';
import HeroTerminalBlock from './HeroTerminalBlock.astro';

const { title, punchline } = hero;
---

<section class="relative flex min-h-[88vh] items-center overflow-hidden py-16 md:py-20">
  <div class="container-main relative z-10 w-full">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16 xl:gap-20">
      <!-- Copy -->
      <div class="max-w-xl">
        <p class="animate-fade-up section-label">{hero.role}</p>

        <h1 class="animate-fade-up-delay-1 mt-8">
          <span
            class="block font-sans text-4xl font-medium leading-[1.08] tracking-tight text-off-white md:text-5xl lg:text-6xl"
          >
            {title}
          </span>
          <span
            class="mt-4 block font-serif text-2xl leading-snug text-off-white/90 md:text-3xl lg:text-4xl"
          >
            {punchline.before}
            <MessyWord word={punchline.messyWord} />
            {punchline.after}
          </span>
        </h1>

      </div>

      <!-- Terminal + status caption (option 2) -->
      <div class="animate-fade-up-delay-2 relative w-full">
        <HeroTerminalBlock />
      </div>
    </div>
  </div>

  <a
    href="#portfolio"
    class="animate-fade-up-delay-4 absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 flex-col items-center gap-0 rounded-sm text-muted-dim transition-colors hover:text-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-accent/40 focus-visible:ring-offset-2 focus-visible:ring-offset-charcoal animate-scroll-hint"
    aria-label="Scroll to projects"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="h-6 w-6"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
        clip-rule="evenodd"></path>
    </svg>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="-mt-1 h-6 w-6"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
        clip-rule="evenodd"></path>
    </svg>
  </a>

  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-charcoal to-transparent"></div>
</section>
