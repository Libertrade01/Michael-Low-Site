---
import { hero, site } from '../config/site';
import StatusDot from './StatusDot.astro';

interface Props {
  variant?: 'inline' | 'card' | 'bold' | 'bar' | 'chips' | 'caption';
}

const { variant = 'card' } = Astro.props;
---

{
  variant === 'caption' && (
    <p
      class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs leading-snug md:text-sm"
      role="status"
      aria-label={`${hero.statusLabel} ${hero.statusPill}`}
    >
      <span class="inline-flex shrink-0 items-center gap-2">
        <StatusDot color="blue" />
        <span class="text-muted">{hero.statusLabel}</span>
      </span>
      <span class="text-off-white/90">{hero.statusPill}</span>
    </p>
  )
}

{
  variant === 'inline' && (
    <p class="font-mono text-sm leading-relaxed text-off-white/80 md:text-base">
      <span class="font-medium text-amber-bright">status:</span>
      <span class="ml-2">{site.availability}</span>
    </p>
  )
}

{
  variant === 'card' && (
    <div class="rounded-xl border border-amber-accent/15 bg-charcoal-card/70 px-5 py-4 backdrop-blur-sm">
      <div class="flex items-start gap-3">
        <StatusDot color="blue" />
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-amber-accent">status</p>
          <p class="mt-1.5 text-sm leading-relaxed text-off-white md:text-[15px]">{site.availability}</p>
        </div>
      </div>
    </div>
  )
}

{
  variant === 'bold' && (
    <div>
      <p class="font-mono text-xs font-medium uppercase tracking-[0.25em] text-amber-bright">status</p>
      <p class="mt-2 text-base font-medium leading-snug text-off-white md:text-lg">{site.availability}</p>
    </div>
  )
}

{
  variant === 'bar' && (
    <div
      class="inline-flex max-w-full items-center gap-2 rounded-full border border-amber-accent/22 bg-charcoal-card/90 px-4 py-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-sm"
      role="status"
      aria-label={`${hero.statusLabel} ${hero.statusPill}`}
    >
      <StatusDot color="blue" />
      <span class="shrink-0 font-mono text-xs font-medium tracking-[0.04em] text-muted">
        {hero.statusLabel}
      </span>
      <span class="min-w-0 font-mono text-xs leading-none text-off-white md:text-sm">
        {hero.statusPill}
      </span>
    </div>
  )
}

{
  variant === 'chips' && (
    <div class="flex flex-wrap gap-2" role="list" aria-label="Availability">
      {
        hero.statusChips.map((chip, i) => (
          <span
            class="inline-flex items-center gap-2 rounded-full border border-amber-accent/15 bg-charcoal/50 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.12em] text-off-white/85"
            role="listitem"
          >
            {i === 0 && <StatusDot color="blue" />}
            {chip}
          </span>
        ))
      }
    </div>
  )
}
