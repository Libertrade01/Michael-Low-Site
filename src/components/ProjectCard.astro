---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import StatusBadge from './StatusBadge.astro';
import TechStack from './TechStack.astro';
import type { ProjectEntry } from '../utils/content';

interface Props {
  project: ProjectEntry;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const { title, description, status, category, type, stack, coverImage, coverFit, coverPosition } =
  project.data;
const coverRetina = coverImage?.replace(/\.(png|jpe?g|webp)$/i, '@2x.$1');
const hasRetinaCover =
  Boolean(coverImage && coverRetina) &&
  existsSync(join(process.cwd(), 'public', coverRetina!.replace(/^\//, '')));
const isPhotoCover = Boolean(coverImage?.match(/\.(png|jpe?g|webp)$/i));
const fit = coverFit ?? (isPhotoCover ? 'contain' : 'cover');
const position = coverPosition ?? (fit === 'contain' ? 'top' : 'center');
const num = String(index + 1).padStart(2, '0');
---

<article class="card-surface project-card group flex flex-col overflow-hidden">
  <a href={`/projects/${project.slug}`} class="flex flex-1 flex-col">
    <div
      class:list={[
        'relative aspect-[16/10] overflow-hidden',
        fit === 'contain' ? 'bg-[#f2f1ec]' : 'bg-charcoal',
      ]}
    >
      {
        coverImage ? (
          <img
            src={coverImage}
            {...(hasRetinaCover
              ? {
                  srcset: `${coverImage} 1x, ${coverRetina} 2x`,
                  sizes: '(min-width: 768px) 50vw, 100vw',
                }
              : {})}
            alt={`${title} preview`}
            class:list={[
              'h-full w-full transition duration-500',
              fit === 'contain'
                ? 'object-contain object-top px-2 pb-1 pt-2 md:px-3 md:pt-3'
                : 'object-cover object-center group-hover:scale-[1.03]',
              position === 'top' && fit === 'cover' && 'object-top',
            ]}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-gradient-to-br from-charcoal-elevated to-charcoal">
            <span class="font-serif text-6xl text-amber-accent/10">{title.charAt(0)}</span>
          </div>
        )
      }
      <span class="absolute left-4 top-4 font-mono text-[10px] text-amber-accent/60">{num}</span>
      <div class="absolute right-4 top-4">
        <StatusBadge status={status} />
      </div>
    </div>

    <div class="project-card__body relative flex flex-1 flex-col p-7 md:p-8">
      <div class="flex flex-wrap items-center gap-2">
        <span class="inline-flex rounded border border-amber-accent/25 bg-amber-accent/5 px-2 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wider text-amber-accent">
          {category}
        </span>
        <span class="font-mono text-[10px] uppercase tracking-wider text-muted">{type}</span>
      </div>
      <h3 class="mt-3 font-serif text-2xl text-off-white transition-colors group-hover:text-amber-bright md:text-[1.65rem] md:leading-snug">
        {title}
      </h3>
      <p class="mt-4 flex-1 text-base leading-relaxed text-muted">{description}</p>
      <div class="mt-5">
        <TechStack stack={stack} variant="inline" />
      </div>
      <span class="link-arrow mt-6">
        Case study
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
