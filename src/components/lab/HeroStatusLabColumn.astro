---
import MessyWord from '../MessyWord.astro';
import { hero } from '../../config/site';

const { title, punchline, role } = hero;
---

<div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
  <div class="max-w-xl">
    <p class="section-label">{role}</p>
    <h2 class="mt-6">
      <span
        class="block font-sans text-3xl font-medium leading-[1.08] tracking-tight text-off-white md:text-4xl"
      >
        {title}
      </span>
      <span class="mt-3 block font-serif text-xl leading-snug text-off-white/90 md:text-2xl">
        {punchline.before}
        <MessyWord word={punchline.messyWord} />
        {punchline.after}
      </span>
    </h2>
    {
      Astro.slots.has('left-footer') && (
        <div class="mt-8">
          <slot name="left-footer" />
        </div>
      )
    }
  </div>
  <div class="w-full">
    <slot />
  </div>
</div>
