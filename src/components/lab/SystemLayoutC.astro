---
import type { SystemPhase } from './system-phases';

interface Props {
  phases: SystemPhase[];
}

const { phases } = Astro.props;
---

<div class="my-2 grid gap-4 sm:grid-cols-2">
  {
    phases.map((phase, i) => (
      <div class="card-surface p-5 md:p-6">
        <div class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-amber-accent/30 bg-amber-accent/10 font-mono text-[10px] text-amber-accent">
            {i + 1}
          </span>
          <div>
            <h3 class="text-[15px] font-medium tracking-tight text-off-white">{phase.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{phase.description}</p>
          </div>
        </div>
      </div>
    ))
  }
</div>
