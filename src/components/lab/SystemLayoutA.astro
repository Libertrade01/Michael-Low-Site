---
import type { SystemPhase } from './system-phases';

interface Props {
  phases: SystemPhase[];
}

const { phases } = Astro.props;
---

<div class="my-2">
  <ol class="relative list-none space-y-0 pl-6 md:pl-7" role="list">
    <div
      class="pointer-events-none absolute bottom-2 left-[4px] top-2 w-px bg-amber-accent/25"
      aria-hidden="true"
    />
    {
      phases.map((phase, i) => (
        <li class:list={['relative', i < phases.length - 1 && 'pb-6 md:pb-7']}>
          <span
            class="absolute -left-6 top-1 box-border h-2 w-2 rounded-full border border-amber-accent/50 bg-charcoal ring-2 ring-charcoal md:-left-7"
            aria-hidden="true"
          />
          <h3 class="text-[15px] font-medium tracking-tight text-off-white md:text-base">
            {phase.title}
          </h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted">{phase.description}</p>
        </li>
      ))
    }
  </ol>
</div>
